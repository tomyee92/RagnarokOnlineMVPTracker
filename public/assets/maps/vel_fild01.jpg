	<div id='review' style='margin: auto;'><div class='review-BL-top'><!-- empty --></div><div class='review-BL-mid'><div style='padding: 3px 0 3px 5px; border-bottom: 2px solid #38719C; text-align: left; margin: 0px 5px;'><img src = 'images/circle.gif'><a href = '/index.php?page=detailedlistserver&serid=23379&url_sname=OTTi Ragnarok' class='sb_m' >
